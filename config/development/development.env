DEBUG=1
SECRET_KEY=insecure-development-secret-key

DJANGO_ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=http://127.0.0.1 https://127.0.0.1

MEDIA_ROOT=media/

DATABASE=postgres
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=postgres
SQL_USER=postgres
SQL_PASSWORD=postgres
SQL_HOST=db-dev
SQL_PORT=5432

# Set to yes to run migrations on load
RUN_MIGRATIONS=yes

# Log level
DJANGO_LOG_LEVEL=WARNING
